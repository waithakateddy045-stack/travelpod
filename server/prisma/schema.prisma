generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  TRAVELER
  TRAVEL_AGENCY
  HOTEL_RESORT
  DESTINATION
  AIRLINE
  ASSOCIATION
  ADMIN
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PostType {
  VIDEO
  PHOTO
  TEXT
  REVIEW
  BROADCAST
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BoostStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  EXPIRED
}

enum BoostTier {
  BRONZE
  SILVER
  GOLD
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CollaborationStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}

enum CompensationType {
  PAID
  FREE_STAY
  COMMISSION
  EXPOSURE
  OTHER
}

enum CommentType {
  COMMENT
  REVIEW
}

enum DeviceType {
  WEB
  ANDROID
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?
  googleId          String?   @unique
  username          String    @unique
  displayName       String?
  bio               String?
  avatarUrl         String?
  websiteUrl        String?
  accountType       AccountType @default(TRAVELER)
  isVerified        Boolean   @default(false)
  isAdmin           Boolean   @default(false)
  isSuspended       Boolean   @default(false)
  onboardingComplete Boolean  @default(false)
  personalityTags   Json?
  preferredRegions  Json?
  followerCount     Int       @default(0)
  followingCount    Int       @default(0)
  totalLikes        Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  posts             Post[]
  comments          Comment[]
  likes             Like[]
  saves             Save[]
  followers         Follow[]  @relation("Following")
  following         Follow[]  @relation("Follower")
  notifications     Notification[]
  sentMessages      Message[] @relation("SentMessages")
  conversations     ConversationParticipant[]
  enquiriesSent     BookingEnquiry[] @relation("EnquirySender")
  enquiriesReceived BookingEnquiry[] @relation("EnquiryReceiver")
  boards            TripBoard[]
  boardLikes        BoardLike[]
  boardSaves        BoardSave[]
  boardFollows      BoardFollow[]
  boardComments     BoardComment[]
  verification      BusinessVerification?
  boostRequests     BoostRequest[]
  badges            UserBadge[]
  collaborationsInitiated Collaboration[] @relation("Initiator")
  collaborationsReceived  Collaboration[] @relation("Receiver")
  reports           Report[]
  sessions          Session[]
  featureFlagUpdates FeatureFlag[]
}

model Session {
  id          String     @id @default(cuid())
  userId      String
  token       String     @unique
  deviceType  DeviceType @default(WEB)
  createdAt   DateTime   @default(now())
  expiresAt   DateTime
  lastActiveAt DateTime  @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id               String          @id @default(cuid())
  userId           String
  postType         PostType        @default(VIDEO)
  title            String?
  description      String?
  textContent      String?
  videoUrl         String?
  thumbnailUrl     String?
  mediaUrls        Json?
  duration         Int?
  location         String?
  locationTag      String?
  category         String?
  tags             Json?
  musicTitle       String?
  moderationStatus ModerationStatus @default(PENDING)
  isReview         Boolean         @default(false)
  reviewOfId       String?
  starRating       Int?
  isBroadcast      Boolean         @default(false)
  broadcastSector  String?
  broadcastRegion  String?
  isPinned         Boolean         @default(false)
  storageAccount   String?
  likeCount        Int             @default(0)
  commentCount     Int             @default(0)
  saveCount        Int             @default(0)
  viewCount        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewOf         Post?           @relation("ReviewOf", fields: [reviewOfId], references: [id])
  reviews          Post[]          @relation("ReviewOf")
  comments         Comment[]
  likes            Like[]
  saves            Save[]
  boardVideos      TripBoardVideo[]
  boostRequests    BoostRequest[]
  reports          Report[]
  collaborations   Collaboration[]
}

model Comment {
  id            String      @id @default(cuid())
  postId        String
  userId        String
  content       String
  commentType   CommentType @default(COMMENT)
  linkedPostId  String?
  createdAt     DateTime    @default(now())

  post          Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Save {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model BookingEnquiry {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  message     String
  travelDates String?
  budget      String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  sender      User     @relation("EnquirySender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("EnquiryReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model TripBoard {
  id              String    @id @default(cuid())
  userId          String
  title           String
  description     String?
  destination     String?
  coverImage      String?
  travelDateFrom  DateTime?
  travelDateTo    DateTime?
  estimatedBudget String?
  isPublic        Boolean   @default(true)
  likeCount       Int       @default(0)
  saveCount       Int       @default(0)
  followerCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos          TripBoardVideo[]
  likes           BoardLike[]
  saves           BoardSave[]
  follows         BoardFollow[]
  comments        BoardComment[]
}

model TripBoardVideo {
  id       String    @id @default(cuid())
  boardId  String
  postId   String
  addedAt  DateTime  @default(now())

  board    TripBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([boardId, postId])
}

model BoardLike {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  createdAt DateTime  @default(now())

  board     TripBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model BoardSave {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  createdAt DateTime  @default(now())

  board     TripBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model BoardFollow {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  createdAt DateTime  @default(now())

  board     TripBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model BoardComment {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  content   String
  createdAt DateTime  @default(now())

  board     TripBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessVerification {
  id                           String             @id @default(cuid())
  userId                       String             @unique
  businessRegistrationNumber   String
  businessRegistrationDocument String?
  associationName              String?
  associationMembershipNumber  String?
  associationDocument          String?
  registeredWebsite            String?
  websiteVerified              Boolean            @default(false)
  verifiedAt                   DateTime?
  verifiedByAdminId            String?
  status                       VerificationStatus @default(PENDING)
  adminNotes                   String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  user                         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BoostRequest {
  id             String      @id @default(cuid())
  userId         String
  postId         String
  duration       Int
  targetAudience String?
  targetRegion   String?
  tier           BoostTier   @default(BRONZE)
  status         BoostStatus @default(PENDING)
  startDate      DateTime?
  endDate        DateTime?
  impressions    Int         @default(0)
  clicks         Int         @default(0)
  adminNotes     String?
  createdAt      DateTime    @default(now())

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String     @id @default(cuid())
  name        String     @unique
  description String
  icon        String
  tier        BadgeTier
  criteria    Json
  createdAt   DateTime   @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Collaboration {
  id               String              @id @default(cuid())
  initiatorId      String
  receiverId       String
  postId           String?
  proposal         String
  contentIdea      String?
  proposedDates    String?
  compensationType CompensationType    @default(EXPOSURE)
  status           CollaborationStatus @default(PENDING)
  createdAt        DateTime            @default(now())

  initiator        User                @relation("Initiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver         User                @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  post             Post?               @relation(fields: [postId], references: [id])
}

model Report {
  id        String   @id @default(cuid())
  postId    String?
  userId    String
  reason    String
  details   String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeatureFlag {
  id               String   @id @default(cuid())
  name             String   @unique
  isEnabled        Boolean  @default(false)
  description      String
  updatedAt        DateTime @updatedAt
  updatedByAdminId String?

  updatedBy        User?    @relation(fields: [updatedByAdminId], references: [id])
}

model AppVersion {
  id           String   @id @default(cuid())
  currentVersion String
  minimumVersion String
  forceUpdate  Boolean  @default(false)
  releaseNotes String?
  downloadUrl  String?
  updatedAt    DateTime @updatedAt
}
